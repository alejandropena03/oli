# Copy to .env.local and fill secrets locally. Never commit .env.local.

# Default development mode. Does not call external providers.
OLI_MODEL_PROVIDER="development"

# Persistence.
# JSON is the default zero-setup local mode.
OLI_MISSION_STORE="json"
OLI_MISSION_STORE_PATH="runtime/missions.json"

# SQLAlchemy mode. Use SQLite for local development, Postgres for canonical TDD runtime.
# OLI_MISSION_STORE="sqlalchemy"
# OLI_DATABASE_URL="sqlite:///runtime/oli-dev.db"
# OLI_DATABASE_URL="postgresql+psycopg2://oli:oli@localhost:5432/oli"

# OpenRouter / OpenAI-compatible API example.
# OLI_MODEL_PROVIDER="openai_compatible"
# OLI_OPENAI_COMPAT_BASE_URL="https://openrouter.ai/api/v1"
# OLI_OPENAI_COMPAT_MODEL="openrouter/owl-alpha"
# OLI_OPENAI_COMPAT_API_KEY="sk-or-your-key"

# Ollama example.
# OLI_MODEL_PROVIDER="ollama"
# OLLAMA_HOST="http://127.0.0.1:11434"
# OLI_OLLAMA_MODEL="qwen2.5:14b"

# Generic webhook example.
# OLI_MODEL_PROVIDER="webhook"
# OLI_WEBHOOK_MODEL_URL="https://example.com/webhook/model"
# OLI_WEBHOOK_MODEL_BEARER_TOKEN=""
